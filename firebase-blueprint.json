{
  "entities": {
    "UserConfig": {
      "title": "User Configuration",
      "description": "Stores user-specific settings, goals, budgets, and financial items.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "sheetId": { "type": "string", "description": "The connected Google Sheet ID." },
        "budget": { "type": "number", "description": "The monthly budget." },
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "target": { "type": "number" },
              "saved": { "type": "number" },
              "icon": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "envelopes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "budget": { "type": "number" },
              "icon": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        },
        "bills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "amount": { "type": "number" },
              "date": { "type": "string" },
              "month": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "soon", "paid"] }
            }
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "value": { "type": "number" }
            }
          }
        },
        "liabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "value": { "type": "number" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserConfig",
      "description": "User configuration and financial data."
    }
  }
}
